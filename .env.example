# FiinQuant credentials (never commit real values)
FIINQUANT_USERNAME=your_username
FIINQUANT_PASSWORD=your_password

# Plan: free (default) | paid
# Free (Trải nghiệm) limits from FiinQuant pricing table:
#   connections=1, 100k req/month, 90/min, 80/s
#   realtime ≤33 tickers, history ≤1 month, TF 1m/5m/15m/1h/4h
FIINQUANT_PLAN=free
FIINQUANT_ENFORCE_PLAN_LIMITS=true
# Override if needed (defaults follow FIINQUANT_PLAN):
# FIINQUANT_MAX_HISTORY_DAYS=31
# FIINQUANT_MAX_REALTIME_TICKERS=33
# FIINQUANT_REQUESTS_PER_MINUTE=90
# FIINQUANT_REQUESTS_PER_SECOND=80

# Reliability / response budgets
FIINQUANT_TIMEOUT_S=30
FIINQUANT_MAX_ROWS=500
FIINQUANT_MAX_CHARS=80000
FIINQUANT_LOG_LEVEL=INFO
